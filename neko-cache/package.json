{
  "name": "@devbro/neko-cache",
  "version": "0.1.15",
  "description": "Driver-agnostic caching library that keeps your data close and your latency lower",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "format": "biome check --write .",
    "prepare": "husky",
    "prettier": "biome format --write .",
    "clean": "rm -rf dist"
  },
  "author": "Farzad Meow Khalafi",
  "license": "MIT",
  "devDependencies": {
    "@types/memcached": "^2.2.10",
    "@types/node": "^24.1.0",
    "husky": "^9.1.7",
    "memcached": "^2.2.2",
    "redis": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@devbro/neko-helper": "0.1.*"
  },
  "peerDependencies": {
    "memcached": "^2.2.2",
    "redis": "^4.6.0"
  },
  "peerDependenciesMeta": {
    "memcached": {
      "optional": true
    },
    "redis": {
      "optional": true
    }
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/devbro1/pashmak.git"
  },
  "keywords": [
    "pashmak"
  ],
  "bugs": {
    "url": "https://github.com/devbro1/pashmak/issues"
  },
  "homepage": "https://devbro1.github.io/pashmak/",
  "tags": {
    "needsCompile": true,
    "canPublishToNpm": true
  }
}
