{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!docs",
      "!**/dist",
      "!**/node_modules",
      "!**/coverage",
      "!**/.git",
      "!**/.github",
      "!neko-config/tests/fixtures/configs_generic/invalid.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noAssignInExpressions": "off",
        "useIterableCallbackReturn": "off",
        "noNonNullAssertedOptionalChain": "off",
        "noAsyncPromiseExecutor": "off",
        "noExplicitAny": "off"
      },
      "correctness": {
        "noUnsafeOptionalChaining": "off",
        "noUnusedFunctionParameters": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  }
}
