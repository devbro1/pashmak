{
  "name": "test_app",
  "version": "1.0.1",
  "main": "index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf dist",
    "dev": "tsx --watch -r tsconfig-paths/register src/index.ts start --all | npx pino-pretty",
    "cli": "tsx -r tsconfig-paths/register src/index.ts",
    "start": "tsx dist/index.js",
    "build": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check . --ext .ts,.tsx",
    "format": "biome format . --ext .ts,.tsx --write"
  },
  "dependencies": {
    "@devbro/pashmak": "^0.1.*",
    "dotenv": "^17.4.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pg-cursor": "^2.19.0",
    "redis": "^5.11.0",
    "tsconfig-paths": "^4.2.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
